#: project/auth.py:45
msgid "Per favore verifica il tuo indirizzo email per continuare"
msgstr "Please verify your email address to continue"

#: project/auth.py:70
msgid "Per favore verifica le tue credenziali e riprova"
msgstr "Please check your credentials and try again"

#: project/auth.py:94
msgid "L'indirizzo email specificato esiste già"
msgstr "The specified email address already exists"

#: project/auth.py:108
#, python-format
msgid "Utente %(user_id)s creato con successo"
msgstr "User %(user_id)s created successfully"

#: project/auth.py:137
msgid "Email verificata con successo!"
msgstr "Email verified successfully!"

#: project/auth.py:140
msgid "Codice di verifica non valido. Riprova."
msgstr "Invalid verification code. Please try again."

#: project/auth.py:178
msgid ""
"Se l'indirizzo email è registrato, riceverai a breve un link per "
"reimpostare la password."
msgstr ""
"If the email address is registered, you will shortly receive a link to "
"reset your password."

#: project/auth.py:194 project/auth.py:208
msgid "Il link di recupero è invalido o scaduto. Richiedine uno nuovo."
msgstr "The recovery link is invalid or expired. Please request a new one."

#: project/auth.py:225
msgid "La tua password è stata aggiornata con successo! Ora puoi fare il login."
msgstr "Your password has been successfully updated! You can now log in."

#: project/auth.py:244
msgid "Il nome deve contenere almeno 3 caratteri."
msgstr "The name must contain at least 3 characters."

#: project/auth.py:246
msgid "Lingua non gestita"
msgstr "Language not supported"

#: project/auth.py:259
msgid "Profilo aggiornato con successo."
msgstr "Profile updated successfully."

#: project/auth.py:271
msgid "La password attuale non è corretta."
msgstr "The current password is incorrect."

#: project/auth.py:291
msgid "Password aggiornata con successo."
msgstr "Password updated successfully."

#: project/auth.py:303
msgid "Password non corretta."
msgstr "Incorrect password."

#: project/auth.py:313
msgid "Email già in uso."
msgstr "Email already in use."

#: project/auth.py:325
msgid "Email aggiornata. Controlla la posta per la verifica."
msgstr "Email updated. Check your inbox for verification."

#: project/auth.py:336
msgid "Password errata. Impossibile eliminare l'account."
msgstr "Incorrect password. Cannot delete the account."

#: project/auth.py:347
msgid "Account eliminato definitivamente."
msgstr "Account permanently deleted."

#: project/auth.py:363
#, python-format
msgid ""
"Ciao %(user_name)s,\n"
"\n"
"Il tuo codice di verifica è: %(verification_code)s\n"
"\n"
"Inseriscilo nell'applicazione per continuare."
msgstr ""
"Hi %(user_name)s,\n"
"\n"
"Your verification code is: %(verification_code)s\n"
"\n"
"Enter it in the application to continue."

#: project/auth.py:371
#, python-format
msgid "[%(app)s] Codice di verifica"
msgstr "[%(app)s] Verification code"

#: project/auth.py:429
#, python-format
msgid ""
"Ciao %(user_name)s,\n"
"\n"
"Per reimpostare la tua password, clicca sul seguente link:\n"
"%(reset_url)s\n"
"\n"
"Se non hai richiesto tu il reset, ignora semplicemente questa email."
msgstr ""
"Hi %(user_name)s,\n"
"\n"
"To reset your password, click on the following link:\n"
"%(reset_url)s\n"
"\n"
"If you didn't request a password reset, please ignore this email."

#: project/auth.py:437
#, python-format
msgid "[%(app)s] Recupero Password"
msgstr "[%(app)s] Password Recovery"

#: project/auth.py:462
msgid "Italiano"
msgstr "Italian"

#: project/auth.py:463
msgid "Inglese"
msgstr "English"

